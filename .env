# Loaded automatically by Expo (SDK 49+) for local `expo start` / `expo run` builds.
# EAS cloud builds use the "env" block in eas.json instead — this file is for
# local development parity, so both paths use the same explicit URL rather
# than silently relying on the hardcoded fallback in src/api/client.ts.
EXPO_PUBLIC_API_URL=https://farmasyst-backend.onrender.com/api/v1
